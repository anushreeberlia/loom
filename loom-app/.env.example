# loom-app — copy to `.env` for local overrides. `shopify app dev` also injects SHOPIFY_*.
# Do not commit real secrets.

# ── Shopify (Partners → App setup) ───────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated, must match shopify.app.toml [access_scopes]
SCOPES=read_products,write_products

# App origin (scheme + host, no trailing path). Must match Partners "App URL" and OAuth redirects.
# Dev:     often set automatically to your *.trycloudflare.com tunnel
# Prod:    e.g. https://app.yourdomain.com  or https://loom-app.up.railway.app
SHOPIFY_APP_URL=

# ── Database (Prisma Session storage) ─────────────────────────────────────────
# Dev (SQLite — default in prisma/schema.prisma):
# DATABASE_URL="file:./dev.sqlite?connection_limit=1"
# Prod: use Postgres on your host, e.g. postgresql://USER:PASS@HOST:5432/DB?sslmode=require
DATABASE_URL=

# ── Loom Python API ─────────────────────────────────────────────────────────
# Used by the embedded app (install / sync / status) and should match the theme block
# "Loom backend URL" merchants set in the theme editor (usually your public API).
# Example: https://loom-style.com
LOOM_BACKEND_URL=https://loom-style.com

# ── Optional ────────────────────────────────────────────────────────────────
# Railway HTTP: use the platform default or 8080. Do not set PORT=5432 (that is Postgres).
# NODE_ENV=production
# SHOP_CUSTOM_DOMAIN=
