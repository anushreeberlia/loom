# loom-app — copy to `.env` for local overrides. `shopify app dev` also injects SHOPIFY_*.
# Do not commit real secrets.

# ── Shopify (Partners → App setup) ───────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated, must match shopify.app.toml [access_scopes]
SCOPES=read_products,write_products

# App origin (scheme + host, no trailing path). Must match Partners "App URL" and OAuth redirects.
# Dev:     often set automatically to your *.trycloudflare.com tunnel
# Prod:    e.g. https://loom-production-xxxx.up.railway.app
SHOPIFY_APP_URL=

# ── Database (Prisma Session storage) — PostgreSQL in production ────────────
# Local (after: docker compose up -d):
# DATABASE_URL="postgresql://loom:loom@localhost:5432/loom_session?schema=public"
# Prod (Railway Postgres): paste the DATABASE_URL from the database plugin (usually includes sslmode).
DATABASE_URL=

# ── Loom Python API ─────────────────────────────────────────────────────────
# Required in production. Used by embedded app + webhook forwarding to Python.
# Example: https://loom-style.com
LOOM_BACKEND_URL=https://loom-style.com

# Optional: shared secret if Python /shopify/notify-uninstall validates Bearer
# LOOM_BACKEND_SHARED_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────
# Railway HTTP: use the platform default or 8080. Do not set PORT=5432 (that is Postgres).
# NODE_ENV=production
# SHOP_CUSTOM_DOMAIN=
