@@ -13,6 +13,22 @@ function respondToBotRequest({ logger }, request) {
         logger.debug('Request is from a Shopify agent, allow');
         return;
     }
+    // Embedded Admin / session-token traffic: never treat as crawlers (isbot false positives → 410 Gone in iframe).
+    let url;
+    try {
+        url = new URL(request.url);
+    } catch {
+        url = undefined;
+    }
+    if (url?.searchParams?.get('embedded') === '1') {
+        return;
+    }
+    if (request.headers.get('Sec-Fetch-Dest') === 'iframe') {
+        return;
+    }
+    if (request.headers.get('Authorization')?.startsWith('Bearer ')) {
+        return;
+    }
     if (isbot.isbot(userAgent)) {
