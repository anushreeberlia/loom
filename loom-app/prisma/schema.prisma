// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Production: PostgreSQL (Railway, Neon, etc.). Session lives in schema `shopify` so `public`
// can hold Python/pgvector tables without collisions. See prisma/BASELINE.md if migrate deploy fails (P3005).
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["shopify"]
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@schema("shopify")
}
