# Database (Railway will set this automatically)
DATABASE_URL=postgresql://localhost:5432/outfit_styler

# Vision backend: "florence" (default, zero-cost) or "openai" (GPT-4o-mini fallback)
VISION_BACKEND=florence

# Fashion Florence HF Space URL (required if VISION_BACKEND=florence)
FLORENCE_API_URL=https://anushreeberlia-fashion-florence-api.hf.space

# OpenAI API (required for Shopify app; used as fallback if Florence is unavailable)
OPENAI_API_KEY=sk-...

# Cloudinary (for image hosting)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

