# ── Database ──────────────────────────────────────────────────────────────────
# Railway sets this automatically; for local dev point at your Postgres instance
DATABASE_URL=postgresql://localhost:5432/outfit_styler

# ── Vision / AI ───────────────────────────────────────────────────────────────
# "florence" (default, zero-cost via HF Space) or "openai" (GPT-4o-mini)
VISION_BACKEND=florence

# Fashion Florence HF Space URL (required when VISION_BACKEND=florence)
FLORENCE_API_URL=https://anushreeberlia-fashion-florence-api.hf.space

# OpenAI API key (required for Shopify app; fallback when Florence is unavailable)
OPENAI_API_KEY=sk-...

# ── Image hosting (Cloudinary) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Weather ───────────────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_key

# ── Shopify App (only needed if running the Shopify integration) ──────────────
# Your Shopify app's API secret (from Partners dashboard → App setup)
SHOPIFY_API_SECRET=shpss_...

